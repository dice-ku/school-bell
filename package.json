                              <span className={`hidden print:inline text-[8px] font-extrabold ${
                                val === '遅' ? 'text-indigo-700' :
                                val === '日' ? 'text-green-700' :
                                val === '責' ? 'text-blue-700' :
                                val === '役' ? 'text-purple-700' :
                                val === '休' ? 'text-slate-350' : 'text-slate-900'
