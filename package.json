                          >
                            <option value="">--</option>
                            {activeStaff.map(s => (
                              <option key={s.id} value={s.id}>{s.name.split(' ')[0]}</option>
                            ))}
                          </select>
                          <span className="hidden print:inline text-[7px] font-semibold text-amber-850">
                            {onCallStaffId ? (activeStaff.find(s => s.id === onCallStaffId)?.name.split(' ')[0] || '') : '—'}
                          </span>
                        </td>
                      );
                    })}
                  </tr>
                </tbody>
              </table>
            </div>

            {/* 一括操作 */}
            <div className="p-4 bg-slate-50 border-t border-slate-150 flex flex-col md:flex-row md:items-center justify-between gap-4 print:hidden">
              <div className="flex items-center gap-1.5 text-slate-500 font-bold text-[11px]">
                <HelpCircle className="h-4 w-4 shrink-0 text-slate-400" />
                <span>生成案が完成したら下の「勤務予定に反映します」を押して本登録を完了してください。手動微調整の内容もそのまま反映されます。</span>
              </div>

              <div className="flex gap-2">
                <button
                  onClick={executeGeneration}
                  className="bg-white hover:bg-slate-100 text-slate-700 border border-slate-300 font-bold py-2 px-4 rounded-lg flex items-center gap-1.5 transition-all cursor-pointer"
                >
                  <RefreshCw className="h-3.5 w-3.5" />
                  <span>アサイン再試行 (再生成)</span>
                </button>

                <button
                  id="apply-draft-to-roster-btn"
                  onClick={handleApply}
                  className="bg-indigo-650 hover:bg-indigo-750 text-white font-bold py-2.5 px-6 rounded-lg flex items-center gap-2 transition-all shadow-md cursor-pointer"
                >
                  <Check className="h-4 w-4" />
                  <span>勤務予定に反映します (完了確認)</span>
                </button>
              </div>
            </div>
          </div>
          
        </div>
      )}

    </div>
  );
}
