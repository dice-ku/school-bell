// src/components/ShiftGeneratorDraft.tsx
import React, { useState, useEffect } from 'react';
import { FacilitySettings, Staff, ShiftCategory, MonthlyRosterData, MonthlyOnCallData } from '../types';
import { getDaysInMonth, getDayOfWeekJapanese, isWeekend } from '../utils/dateUtils';
import { Sparkles, CheckCircle2, AlertCircle, RefreshCw, Info, HelpCircle, CalendarDays, Check, Printer } from 'lucide-react';
import { calculateMonthlyCompliance } from '../utils/staffingCalc';

interface ShiftGeneratorDraftProps {
  settings: FacilitySettings;
  staffList: Staff[];
  shifts: ShiftCategory[];
  rosters: Record<string, MonthlyRosterData>;
  onCallData: MonthlyOnCallData;
  onApplySchedule: (newRosters: Record<string, MonthlyRosterData>, newOnCall: MonthlyOnCallData) => void;
  onCancel: () => void;
}

export default function ShiftGeneratorDraft({
  settings,
  staffList,
  shifts,
  rosters,
  onCallData,
  onApplySchedule,
  onCancel
}: ShiftGeneratorDraftProps) {
  const yearMonth = settings.targetYearMonth;
  const daysInMonth = getDaysInMonth(yearMonth);
  const daysArray = Array.from({ length: daysInMonth }, (_, i) => i + 1);
  const activeStaff = staffList.filter(s => s.isActive);

  // ドラフト用のローカルステート
  const [draftRosters, setDraftRosters] = useState<Record<string, MonthlyRosterData>>({});
  const [draftOnCall, setDraftOnCall] = useState<MonthlyOnCallData>({ yearMonth, days: {} });
  
  // 職員ごとの設定を一時的に調整可能にする
  const [draftStaff, setDraftStaff] = useState<Staff[]>([]);
  const [isGenerated, setIsGenerated] = useState<boolean>(false);
  const [showConfig, setShowConfig] = useState<boolean>(true);

  // 初期化
  useEffect(() => {
    // 既存の予定コピー、または空の構造作成
    const initial: Record<string, MonthlyRosterData> = {};
    activeStaff.forEach(s => {
      const existing = rosters[s.id];
      initial[s.id] = {
        yearMonth,
        staffId: s.id,
        schedule: existing ? { ...existing.schedule } : {},
        actual: existing ? { ...existing.actual } : {}
      };
    });
    setDraftRosters(initial);

    // オンコール初期化
    const onCallCopy: MonthlyOnCallData = {
      yearMonth,
      days: onCallData && onCallData.days ? JSON.parse(JSON.stringify(onCallData.days)) : {}
    };
    setDraftOnCall(onCallCopy);

    // スタッフの希望休などの情報をコピー
    setDraftStaff(JSON.parse(JSON.stringify(activeStaff)));
  }, [rosters, onCallData, staffList, yearMonth]);

  // 指定職員の希望休更新
  const handlePreferenceOffDaysChange = (staffId: string, daysStr: string) => {
    const days = daysStr.split(',').map(s => parseInt(s.trim(), 10)).filter(n => !isNaN(n) && n >= 1 && n <= 31);
    setDraftStaff(prev => prev.map(s => s.id === staffId ? { ...s, preferredOffDays: days } : s));
  };

  // 指定非常勤職員の勤務可能曜日更新
  const handlePrefDaysOfWeekChange = (staffId: string, day: string, checked: boolean) => {
    setDraftStaff(prev => prev.map(s => {
      if (s.id === staffId) {
        const current = s.availableDaysOfWeek || [];
        const next = checked ? [...current, day] : current.filter(d => d !== day);
        return { ...s, availableDaysOfWeek: next };
      }
      return s;
    }));
  };

  // セルの直接手動修正
  const handleCellChange = (staffId: string, day: number, symbol: string) => {
    setDraftRosters(prev => {
      const updated = { ...prev };
      if (!updated[staffId]) {
        updated[staffId] = { yearMonth, staffId, schedule: {}, actual: {} };
      }
      updated[staffId] = {
        ...updated[staffId],
        schedule: {
          ...updated[staffId].schedule,
          [String(day)]: symbol
        }
      };
      return updated;
    });
  };

  // オンコールセルの直接手動修正
  const handleOnCallChange = (day: number, staffId: string) => {
    setDraftOnCall(prev => {
      const updated = { ...prev };
      if (!updated.days) updated.days = {};
      if (!updated.days[String(day)]) {
        updated.days[String(day)] = {
          staffId,
          emergency: { active: 'なし', startTime: '', endTime: '', content: '' },
          notes: ''
        };
      } else {
        updated.days[String(day)] = {
          ...updated.days[String(day)],
          staffId
        };
      }
      return updated;
    });
  };

  /**
   * スマート自動生成ロジック
   */
  const executeGeneration = () => {
    const newRosters: Record<string, MonthlyRosterData> = {};
    const newOnCall: MonthlyOnCallData = { yearMonth, days: {} };

    // ローカルストレージまたはpropsから承認済み希望申請をロード
    const localRequestsStr = localStorage.getItem(`roster_app_requests_${yearMonth}`) || localStorage.getItem('roster_app_requests');
    let loadedRequests: any[] = [];
    try {
      if (localRequestsStr) loadedRequests = JSON.parse(localRequestsStr);
    } catch (e) {
      console.error(e);
    }
    const approvedRequests = loadedRequests.filter((r: any) => r.targetMonth === yearMonth && r.status === 'approved');

    // 各自の初期化
    draftStaff.forEach(s => {
      newRosters[s.id] = {
        yearMonth,
        staffId: s.id,
        schedule: {},
        actual: {}
      };

      // 既存の有休(有、代)指定があれば保持する
      const existing = rosters[s.id];
      if (existing && existing.schedule) {
        Object.keys(existing.schedule).forEach(dayKey => {
          const sym = existing.schedule[dayKey];
          if (sym === '有' || sym === '代') {
            newRosters[s.id].schedule[dayKey] = sym;
          }
        });
      }

      // 承認された休暇系希望申請のプリセット
      approvedRequests.filter((r: any) => r.staffId === s.id).forEach((r: any) => {
        const dStr = r.targetDate.split('-')[2];
        const dayKey = String(Number(dStr));
        
        if (r.requestType === '有休希望' || r.requestType === '有休確定') {
          newRosters[s.id].schedule[dayKey] = '有';
        } else if (r.requestType === '代休希望' || r.requestType === '代休確定') {
          newRosters[s.id].schedule[dayKey] = '代';
        } else if (r.requestType === '希望休' || r.requestType === '勤務不可') {
          newRosters[s.id].schedule[dayKey] = '休';
        }
      });
    });

    // 支援可能スタッフ、サビ管スタッフ、その他を取得
    const supportStaff = draftStaff.filter(s => s.isActive && s.includeInStaffing && s.role !== 'サービス管理責任者' && s.role !== '管理者兼サービス管理責任者');
    const sekiStaff = draftStaff.filter(s => s.isActive && (s.isSeki || s.role === 'サービス管理責任者' || s.role === '管理者兼サービス管理責任者'));
    const otherStaff = draftStaff.filter(s => s.isActive && !s.includeInStaffing && !s.isSeki && s.role !== '管理者兼生活支援員');

    // 連勤・土日配分・偏り対策用の稼働カウント用テンポラリ変数
    const weekendCount: Record<string, number> = {};
    const totalDaysCount: Record<string, number> = {};
    supportStaff.forEach(s => {
      weekendCount[s.id] = 0;
      totalDaysCount[s.id] = 0;
    });

    // 1日から順番に配置する
    for (let d = 1; d <= daysInMonth; d++) {
      const dayOfWeek = getDayOfWeekJapanese(yearMonth, d);
      const isWe = isWeekend(yearMonth, d);

      // --- 1. サービス管理責任者 (自動アサイン: 平日はサビ管「責」、土日は基本「休」、希望休優先) ---
      sekiStaff.forEach(s => {
        if (newRosters[s.id].schedule[String(d)]) return;

        const isPrefOff = s.preferredOffDays?.includes(d);
        if (isPrefOff || isWe) {
          newRosters[s.id].schedule[String(d)] = '休';
        } else {
          newRosters[s.id].schedule[String(d)] = '責';
        }
      });

      // --- 2. その他（管理者など：土日休み、平日は管理日勤「役」、希望休優先） ---
      otherStaff.forEach(s => {
        if (newRosters[s.id].schedule[String(d)]) return;

        const isPrefOff = s.preferredOffDays?.includes(d);
        if (isPrefOff || isWe) {
          newRosters[s.id].schedule[String(d)] = '休';
        } else {
          newRosters[s.id].schedule[String(d)] = '役';
        }
      });

      // --- 3. 生活支援員 (主要アサイン) ---
      if (isWe) {
        // 週末に稼動可能な常勤支援員
        const eligibleWeekendStaff = supportStaff.filter(s => {
          if (newRosters[s.id].schedule[String(d)]) return false;
          if (s.preferredOffDays?.includes(d)) return false;
          
          const hasApprovedOffReq = approvedRequests.some((r: any) => 
            r.staffId === s.id && 
            r.targetDate === `${yearMonth}-${String(d).padStart(2, '0')}` && 
            ['希望休', '有休希望', '有休確定', '代休希望', '代休確定', '勤務不可', '土日勤務不可'].includes(r.requestType)
          );
          if (hasApprovedOffReq) return false;

          if (!s.isFullTime && s.availableDaysOfWeek && !s.availableDaysOfWeek.includes(dayOfWeek)) return false;
          return true;
        });

        // 週末出勤回数が最少の人を「遅番」にアサイン
        eligibleWeekendStaff.sort((a, b) => (weekendCount[a.id] || 0) - (weekendCount[b.id] || 0));

        if (eligibleWeekendStaff.length > 0) {
          const selected = eligibleWeekendStaff[0];
          newRosters[selected.id].schedule[String(d)] = '遅';
          weekendCount[selected.id] = (weekendCount[selected.id] || 0) + 1;
          totalDaysCount[selected.id] = (totalDaysCount[selected.id] || 0) + 1;

          // 残りの週末稼動支援員は「休」にする
          eligibleWeekendStaff.slice(1).forEach(s => {
            newRosters[s.id].schedule[String(d)] = '休';
          });
        }

        // 稼動資格がなかった他の職員もすべて「休」
        supportStaff.forEach(s => {
          if (!newRosters[s.id].schedule[String(d)]) {
            newRosters[s.id].schedule[String(d)] = '休';
          }
        });
      }
      else {
        // 平日の配置方針: 日中支援3人以上、宿泊支援「遅番」1名以上を配備
        supportStaff.forEach(s => {
          if (newRosters[s.id].schedule[String(d)]) return;

          const isPrefOff = s.preferredOffDays?.includes(d);
          const isPtOutOfDay = !s.isFullTime && s.availableDaysOfWeek && !s.availableDaysOfWeek.includes(dayOfWeek);

          if (isPrefOff || isPtOutOfDay) {
            newRosters[s.id].schedule[String(d)] = '休';
          }
        });

        const pendingStaff = supportStaff.filter(s => !newRosters[s.id].schedule[String(d)]);

        // 鈴木は週1日、管理者日勤専任「役」に
        pendingStaff.forEach(s => {
          if (s.id === 'S003' && d % 5 === 2) {
            newRosters[s.id].schedule[String(d)] = '役';
          }
        });

        // 遅番決定
        const availableForLate = pendingStaff.filter(s => {
          if (s.id === 'S003' && newRosters[s.id].schedule[String(d)] === '役') return false;
          
          const hasApprovedNoLate = approvedRequests.some((r: any) => 
            r.staffId === s.id && 
            r.targetDate === `${yearMonth}-${String(d).padStart(2, '0')}` && 
            r.requestType === '遅番不可'
          );
          if (hasApprovedNoLate) return false;

          if (d > 1) {
            const yesterdayShift = newRosters[s.id].schedule[String(d - 1)];
            if (yesterdayShift === '遅') return false;
          }
          return s.isFullTime;
        });

        availableForLate.sort((a, b) => (totalDaysCount[a.id] || 0) - (totalDaysCount[b.id] || 0));

        if (availableForLate.length > 0) {
          const selected = availableForLate[0];
          newRosters[selected.id].schedule[String(d)] = '遅';
          totalDaysCount[selected.id] = (totalDaysCount[selected.id] || 0) + 1;
        }

        // 非常勤は可能曜日に合致していれば優先して「日」に
        const stillPending = supportStaff.filter(s => !newRosters[s.id].schedule[String(d)]);
        stillPending.forEach(s => {
          if (!s.isFullTime && s.availableDaysOfWeek?.includes(dayOfWeek)) {
            newRosters[s.id].schedule[String(d)] = '日';
            totalDaysCount[s.id] = (totalDaysCount[s.id] || 0) + 1;
          }
        });

        // 残余の常勤を「日」か「休」に
        const restPending = supportStaff.filter(s => !newRosters[s.id].schedule[String(d)]);
        restPending.forEach(s => {
          let recentWorkCount = 0;
          if (d > 5) {
            for (let i = 1; i <= 4; i++) {
              const prevShift = newRosters[s.id].schedule[String(d - i)];
              if (prevShift && prevShift !== '休' && prevShift !== '有' && prevShift !== '代') {
                recentWorkCount++;
              }
            }
          }

          if (recentWorkCount >= 4) {
            newRosters[s.id].schedule[String(d)] = '休';
          } else {
            newRosters[s.id].schedule[String(d)] = '日';
            totalDaysCount[s.id] = (totalDaysCount[s.id] || 0) + 1;
          }
        });
      }

      // --- 4. オンコール担当割当 ---
      const candidateForOnCall = [...supportStaff, ...otherStaff].filter(s => {
        const todayShift = newRosters[s.id]?.schedule?.[String(d)];
        const hasApprovedNoOnCall = approvedRequests.some((r: any) => 
          r.staffId === s.id && 
          r.targetDate === `${yearMonth}-${String(d).padStart(2, '0')}` && 
          r.requestType === 'オンコール不可'
        );
        if (hasApprovedNoOnCall) return false;
        return todayShift !== '遅' && s.id !== 'S005';
      });

      if (candidateForOnCall.length > 0) {
        const idx = (d - 1) % candidateForOnCall.length;
        const oStaff = candidateForOnCall[idx];

        newOnCall.days[String(d)] = {
          staffId: oStaff.id,
          emergency: { active: 'なし', startTime: '', endTime: '', content: '' },
          notes: ''
        };
      } else {
        newOnCall.days[String(d)] = {
          staffId: '',
          emergency: { active: 'なし', startTime: '', endTime: '', content: '' },
          notes: ''
        };
      }
    }

    setDraftRosters(newRosters);
    setDraftOnCall(newOnCall);
    setIsGenerated(true);
    setShowConfig(false);
  };

  /**
   * 生成案の検証
   */
  const evaluateDraft = () => {
    if (!isGenerated) return null;

    const tempCompliance = calculateMonthlyCompliance(
      settings,
      draftStaff,
      shifts,
      draftRosters,
      draftOnCall,
      false
    );

    const daysFullyStaffedNum: number[] = [];
    const dayDeficitDays: number[] = [];
    const nightDeficitDays: number[] = [];
    const onCallUnassignedDays: number[] = [];
    const preferredHolidayCollisions: { day: number, name: string }[] = [];
    const availabilityViolations: { day: number, name: string, reason: string }[] = [];
    const warningList: string[] = [];

    const staffWorkStreak: Record<string, number> = {};
    const staffMaxStreak: Record<string, number> = {};
    const staffWeekendCount: Record<string, number> = {};
    const staffMonthlyHours: Record<string, number> = {};

    activeStaff.forEach(s => {
      staffWorkStreak[s.id] = 0;
      staffMaxStreak[s.id] = 0;
      staffWeekendCount[s.id] = 0;
      staffMonthlyHours[s.id] = 0;
    });

    tempCompliance.forEach(res => {
      const d = res.day;
      const dayOfWeek = getDayOfWeekJapanese(yearMonth, d);

      if (res.dayCompliance === '不足') {
        dayDeficitDays.push(d);
      }
      if (res.nightCompliance === '不足') {
        nightDeficitDays.push(d);
      }
      if (res.dayCompliance === '充足' && res.nightCompliance === '充足') {
        daysFullyStaffedNum.push(d);
      }

      if (!res.onCallStaffId) {
        onCallUnassignedDays.push(d);
      }

      draftStaff.forEach(s => {
        const roster = draftRosters[s.id];
        const shiftSym = roster?.schedule?.[String(d)];
        if (!shiftSym) return;

        const shiftCat = shifts.find(sh => sh.symbol === shiftSym);
        const isWorking = shiftCat && !shiftCat.isHoliday && shiftSym !== '有' && shiftSym !== '代';

        if (isWorking) {
          const hrs = shiftCat.workHours || 0;
          staffMonthlyHours[s.id] = (staffMonthlyHours[s.id] || 0) + hrs;

          if (res.isHoliday) {
            staffWeekendCount[s.id] = (staffWeekendCount[s.id] || 0) + 1;
          }

          if (s.preferredOffDays?.includes(d)) {
            preferredHolidayCollisions.push({ day: d, name: s.name });
          }

          if (!s.isFullTime && s.availableDaysOfWeek) {
            if (!s.availableDaysOfWeek.includes(dayOfWeek)) {
              availabilityViolations.push({
                day: d,
                name: s.name,
                reason: `${dayOfWeek}曜日は固定休日条件（可能曜日：${s.availableDaysOfWeek.join(',')}）`
              });
            }
          }

          staffWorkStreak[s.id]++;
          if (staffWorkStreak[s.id] > (staffMaxStreak[s.id] || 0)) {
            staffMaxStreak[s.id] = staffWorkStreak[s.id];
          }

          if (d < daysInMonth) {
            const nextDayShiftSym = roster?.schedule?.[String(d + 1)];
            if (shiftSym === '遅' && nextDayShiftSym === '出') {
              warningList.push(`${d}日〜${d+1}日: ${s.name}が遅番の翌日に早出(出)勤務となっており、インターバルが極めて短くなっています。`);
            }
          }
        } else {
          staffWorkStreak[s.id] = 0;
        }
      });
    });

    draftStaff.forEach(s => {
      const maxStr = staffMaxStreak[s.id] || 0;
      if (maxStr >= 6) {
        warningList.push(`${s.name}に最大 ${maxStr}日間 の連続勤務が発生しています。（極端な連勤は避けて調整してください）`);
      }

      if (!s.isFullTime && s.monthlyContractedHours) {
        const actualHrs = staffMonthlyHours[s.id] || 0;
        if (actualHrs > s.monthlyContractedHours) {
          availabilityViolations.push({
            day: 999,
            name: s.name,
            reason: `上限超過：実働 ${actualHrs}時間 (月所定 ${s.monthlyContractedHours}時間制限)`
          });
        }
      }
    });

    const fullTimeSupport = draftStaff.filter(s => s.isActive && s.isFullTime && s.includeInStaffing && s.role === '生活支援員');
    if (fullTimeSupport.length > 1) {
      const weCounts = fullTimeSupport.map(s => staffWeekendCount[s.id] || 0);
      const maxWe = Math.max(...weCounts);
      const minWe = Math.min(...weCounts);
      if (maxWe - minWe >= 3) {
        warningList.push(`常勤支援員間で土日勤務日数に偏りがあります。（最大: ${maxWe}日、最小: ${minWe}日、差: ${maxWe - minWe}日）。手動での調整を推奨します。`);
      }
    }

    if (fullTimeSupport.length > 1) {
      const hrs = fullTimeSupport.map(s => staffMonthlyHours[s.id] || 0);
      const maxHrs = Math.max(...hrs);
      const minHrs = Math.min(...hrs);
      if (maxHrs - minHrs > 16) {
        warningList.push(`常勤支援員間で月間勤務時間に偏りがあります（差: ${Math.round(maxHrs - minHrs)}時間）。健康経営および公平配分のため均等化を図ってください。`);
      }
    }

    return {
      daysFullyStaffedNum,
      dayDeficitDays,
      nightDeficitDays,
      onCallUnassignedDays,
      preferredHolidayCollisions,
      availabilityViolations,
      warningList,
      tempCompliance
    };
  };

  const results = evaluateDraft();

  const handleApply = () => {
    if (confirm('【反映の確認】\nこの「生成案(下書き)」を正式な月別勤務予定表に反映して上書きします。よろしいですか？\n※適用後、通常の「勤務シフト入力」タブでさらに手動で自由に変更可能です。')) {
      const newDrafts: Record<string, boolean> = {};
      activeStaff.forEach(s => {
        daysArray.forEach(d => {
          newDrafts[`${s.id}-${d}`] = true;
        });
      });
      localStorage.setItem(`roster_app_draft_cells_${yearMonth}`, JSON.stringify(newDrafts));

      onApplySchedule(draftRosters, draftOnCall);
    }
  };

  return (
    <div className="space-y-6" id="shift-draft-workspace">
      
      {/* イントロダクション */}
      <div className="bg-gradient-to-r from-blue-700 to-indigo-800 text-white rounded-2xl p-6 shadow-md border border-indigo-700 print:hidden">
        <div className="flex items-start justify-between">
          <div className="space-y-2">
            <div className="flex items-center gap-2 bg-blue-900/30 w-fit px-3 py-1 rounded-full text-xs font-bold border border-blue-400/20">
              <Sparkles className="h-4 w-4 text-blue-300" />
              <span>宿泊型自立訓練 特化型AI・自動アサイン・アシスタント</span>
            </div>
            <h2 className="text-xl font-bold tracking-tight">勤務配置スケジュール「生成案」作成・調律センター</h2>
            <p className="text-xs text-blue-100 leading-relaxed max-w-4xl">
              本機は稼動基準（法定配置比率・夜間宿直1名以上）を可能な限り充足するシフト案を数秒で算出します。<br />
              <strong>【重要】</strong> 自動生成は完全な正解を保証するものではありません。<strong>「生成案」「要確認」「手動調整が必要」</strong>なスケジュールとして、利用者が十分に内容を確認・調正し、画面下の<strong>「勤務予定に反映」</strong>ボタンをクリックした段階で初めて稼動マスターデータベースへ適用されます。
            </p>
          </div>
          
          <button
            onClick={onCancel}
            className="bg-white/10 hover:bg-white/20 text-white border border-white/20 px-3 py-1.5 rounded-lg text-xs font-bold transition-all cursor-pointer"
          >
            戻る
          </button>
        </div>
      </div>

      {/* 条件設定マトリクス */}
      <div className="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden print:hidden">
        <div className="p-4 border-b border-slate-150 bg-slate-50 flex items-center justify-between">
          <div className="flex items-center gap-2 text-slate-800 font-bold text-sm">
            <CalendarDays className="h-4 w-4 text-slate-500" />
            <span>自動配置条件・個別ポリシーの調整設定</span>
          </div>
          <button
            onClick={() => setShowConfig(!showConfig)}
            className="text-xs text-blue-600 hover:text-blue-800 font-bold flex items-center gap-1 cursor-pointer"
          >
