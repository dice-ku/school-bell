                              }`}
                              style={{ borderStyle: 'dashed' }}
                            >
                              <select
                                value={val}
                                onChange={(e) => handleCellChange(staff.id, day, e.target.value)}
                                className={`w-8 rounded text-[10px] font-semibold text-center py-0.5 bg-white border border-slate-200 focus:outline-none focus:ring-1 focus:ring-indigo-500 cursor-pointer print:hidden ${
                                  val === '遅' ? 'text-indigo-700 bg-indigo-50/30 font-bold' :
                                  val === '日' ? 'text-green-700 bg-green-50/30' :
                                  val === '責' ? 'text-blue-700 font-medium' :
                                  val === '役' ? 'text-purple-700 font-medium' :
                                  val === '休' ? 'text-slate-400' : ''
                                }`}
                              >
                                {shifts.map(sh => (
                                  <option key={sh.symbol} value={sh.symbol}>
                                    {sh.symbol}
