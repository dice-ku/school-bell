                          const isPrefOff = staff.preferredOffDays?.includes(day);
                          const availableDays = staff.availableDaysOfWeek;
                          const dayOfWeek = getDayOfWeekJapanese(yearMonth, day);

                          // 非常勤で、勤務日指定範囲外
                          const isPtViolation = !staff.isFullTime && availableDays && !availableDays.includes(dayOfWeek) && val !== '休';
