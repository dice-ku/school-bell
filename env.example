// src/components/ExcelExport.tsx
import React from 'react';
import { 
  FacilitySettings, 
  Staff, 
  ShiftCategory, 
  MonthlyRosterData, 
  MonthlyOnCallData, 
  DailyComplianceResult, 
  MonthlyFteResult 
} from '../types';
import { 
  FileSpreadsheet, 
  Download, 
  ShieldCheck, 
  PhoneCall, 
  Briefcase, 
  Layers, 
  Calendar, Check, CheckCircle2 
} from 'lucide-react';
import { 
  exportMonthlyRoster, 
  exportDailyCompliance, 
  exportMonthlyFte, 
  exportOnCallReport, 
  exportBundleAuditingWorkbook 
} from '../utils/excelExport';

interface ExcelExportProps {
  settings: FacilitySettings;
  staffList: Staff[];
  shifts: ShiftCategory[];
  rosters: Record<string, MonthlyRosterData>;
  onCallData: MonthlyOnCallData;
  complianceResults: DailyComplianceResult[];
  fteResult: MonthlyFteResult;
}

export default function ExcelExport({
  settings,
  staffList,
  shifts,
  rosters,
  onCallData,
  complianceResults,
  fteResult
}: ExcelExportProps) {
  
  return (
    <div className="space-y-6" id="excel-export-center">
      {/* 統合監査一括ダウンロードバナー */}
      <div className="bg-slate-900 text-white p-6 rounded-2xl shadow-sm border border-slate-800 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
        <div>
          <span className="bg-white/10 text-slate-300 text-[10px] font-bold py-1 px-3 rounded-full uppercase tracking-wider">
            ワンクリック監査対策
          </span>
          <h2 className="text-lg font-bold mt-2">障害福祉サービス 監査一括適合証明ブック</h2>
          <p className="text-xs text-slate-300 mt-1 max-w-xl leading-relaxed">
            「日別配置適格判定」と「月間常勤換算(FTE)証明」の双方が1ファイルにまとまった、実地指導・行政監査の提出要求にそのまま対応できる合算マルチシートExcelです。
          </p>
        </div>
        <button
          onClick={() => exportBundleAuditingWorkbook(settings, staffList, shifts, rosters, onCallData, complianceResults, fteResult)}
          className="bg-white text-slate-900 hover:bg-slate-100 font-bold text-xs py-3 px-6 rounded-lg flex items-center gap-2 transition-all shadow-md cursor-pointer shrink-0"
          id="download-master-bundle-btn"
        >
          <Layers className="h-4 w-4 text-blue-600" />
          <span>監査用一括Excelバインダーの出力</span>
        </button>
      </div>

      {/* 個別帳票ダウンロードグリッド */}
      <div>
        <h3 className="text-slate-900 font-bold text-sm mb-4">個別対象帳票のダウンロード一覧</h3>
        
        <div className="grid grid-cols-1 md:grid-cols-2 gap-4" id="direct-downloads-grid">
          
          {/* カード1: 配置判定 */}
          <div className="bg-white p-5 rounded-xl border border-slate-200 flex flex-col justify-between hover:shadow-xs transition-shadow">
            <div>
              <div className="flex gap-2 items-center text-blue-700 font-bold text-sm">
                <ShieldCheck className="h-5 w-5 shrink-0" />
                <span>日別実配置確認・適格判定表</span>
              </div>
              <p className="text-xs text-gray-500 mt-2 leading-relaxed">
                対象：<strong>指定都市・都道府県の指定監査係（実地指導用）</strong><br />
                毎日日中の定員基準(18名に対し3名配置)、および夜間1名以上の物理勤務割振について、30分枠ごとの整合性を証明する最重要のエビデンス帳票です。
              </p>
            </div>
            <button
              onClick={() => exportDailyCompliance(settings, complianceResults)}
              className="mt-4 w-full bg-slate-50 hover:bg-slate-100 text-slate-800 font-bold text-xs py-2 px-3 border border-slate-200 hover:border-slate-300 rounded-lg flex items-center justify-center gap-1.5 transition-all text-center"
              id="download-compliance-btn"
            >
              <Download className="h-3.5 w-3.5" />
              <span>日別実配置確認表の出力 (.xlsx)</span>
            </button>
          </div>

          {/* カード2: 常勤換算 */}
          <div className="bg-white p-5 rounded-xl border border-slate-200 flex flex-col justify-between hover:shadow-xs transition-shadow">
            <div>
              <div className="flex gap-2 items-center text-green-700 font-bold text-sm">
                <Briefcase className="h-5 w-5 shrink-0" />
                <span>月間常勤換算(FTE)算定確認書</span>
              </div>
              <p className="text-xs text-slate-500 mt-2 leading-relaxed">
                対象：<strong>介護障害福祉課 請求審査チーム（監査確証用）</strong><br />
                職員の契約週時間(36.5h基準)に基づき、実働時間、有給、管理業務専任などの除外を適正に按分計算したうえで、適合合計FTE of computed math sheets.
              </p>
            </div>
            <button
              onClick={() => exportMonthlyFte(settings, fteResult)}
              className="mt-4 w-full bg-slate-50 hover:bg-slate-100 text-slate-800 font-bold text-xs py-2 px-3 border border-slate-200 hover:border-slate-300 rounded-lg flex items-center justify-center gap-1.5 transition-all text-center cursor-pointer"
              id="download-fte-btn"
            >
              <Download className="h-3.5 w-3.5" />
              <span>月間常勤換算表の出力 (.xlsx)</span>
            </button>
          </div>

          {/* カード3: オンコール実績 */}
          <div className="bg-white p-5 rounded-xl border border-slate-200 flex flex-col justify-between hover:shadow-xs transition-shadow">
            <div>
              <div className="flex gap-2 items-center text-indigo-700 font-bold text-sm">
                <PhoneCall className="h-5 w-5 shrink-0" />
                <span>オンコール勤務確認表（総務提出）</span>
              </div>
              <p className="text-xs text-slate-500 mt-2 leading-relaxed">
                対象：<strong>施設総務課・給与計算センター（労務受領用）</strong><br />
                日別の待機担当者、当日の電話および誤報等の緊急パトロール対応ログを「確認承認印枠」を含んだA4横向きの様式で作成。待機手当や時間外対応の精算時に最適です。
              </p>
            </div>
            <button
              onClick={() => exportOnCallReport(settings, staffList, onCallData)}
              className="mt-4 w-full bg-slate-50 hover:bg-slate-100 text-slate-800 font-bold text-xs py-2 px-3 border border-slate-200 hover:border-slate-300 rounded-lg flex items-center justify-center gap-1.5 transition-all text-center cursor-pointer"
              id="download-oncall-btn"
            >
              <Download className="h-3.5 w-3.5" />
              <span>オンコール確認表の出力 (.xlsx)</span>
            </button>
          </div>

          {/* カード4: 予定表 & 実績表 */}
          <div className="bg-white p-5 rounded-xl border border-slate-200 flex flex-col justify-between hover:shadow-xs transition-shadow">
            <div>
              <div className="flex gap-2 items-center text-slate-700 font-bold text-sm">
                <Calendar className="h-5 w-5 shrink-0" />
                <span>月別勤務予定表 / 勤務実績表</span>
              </div>
              <p className="text-xs text-slate-500 mt-2 leading-relaxed">
                対象：<strong>全職員、または事業所内掲示用（労務管理・突合）</strong><br />
                日ごとの勤務配置シミュレーション、および事後実績の1ヶ月間のマトリクス表をそのまま出力し、予定・実績の差異（突発欠勤や代理勤務）を監査官に指し示すための原簿です。
              </p>
            </div>
            
            <div className="grid grid-cols-2 gap-2 mt-4">
              <button
                onClick={() => exportMonthlyRoster(settings, staffList, shifts, rosters, false)}
                className="bg-slate-50 hover:bg-slate-100 text-slate-800 font-semibold text-[11px] py-2 px-2 border border-slate-200 hover:border-slate-300 rounded-lg flex items-center justify-center gap-1 transition-all cursor-pointer"
                id="download-plan-btn"
              >
                <Download className="h-3 w-3" />
                <span>予定表の出力</span>
              </button>
              <button
                onClick={() => exportMonthlyRoster(settings, staffList, shifts, rosters, true)}
                className="bg-slate-50 hover:bg-slate-100 text-slate-800 font-semibold text-[11px] py-2 px-2 border border-slate-200 hover:border-slate-300 rounded-lg flex items-center justify-center gap-1 transition-all cursor-pointer"
                id="download-actual-btn"
              >
                <Download className="h-3 w-3" />
                <span>実績表の出力</span>
              </button>
            </div>
          </div>

        </div>
      </div>

      {/* ガイドラインの案内 */}
      <div className="bg-amber-50 rounded-xl border border-amber-200/50 p-5 space-y-2 text-xs text-amber-900 leading-relaxed">
        <h4 className="font-bold flex items-center gap-1"><CheckCircle2 className="h-4 w-4 text-amber-700 shrink-0" /> 行政監査・実地指導に臨むための３大準備事項</h4>
        <ul className="list-disc list-inside space-y-1 text-amber-800">
          <li><strong>常勤職員の勤務証明:</strong> 単に1.0人表記で済ませず、当月基準時間（例：156.4時間）に対する実労働時間、有給休暇取得記録（有給記号時間も換算対象）との合算整合性が確認されています。</li>
          <li><strong>生活支援員以外（サビ管専従、管理者専従など）の除外：</strong> 支援員と他の兼務時間を重複させない、あるいはサビ管を勝手に支援員の配置として計上しないようにマスタ＆記号別に弾かれています。</li>
          <li><strong>オンコールの除外：</strong> 総務課へ提出するオンコール待機実績の手当対象者と、配置加算の勤務時間は完全分離されて出力されます。</li>
        </ul>
      </div>
    </div>
  );
}
