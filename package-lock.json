            </div>

          </div>

          {/* 表履歴グリッドの完全再現 (画像の再現) */}
          <div className="bg-white rounded-xl border border-slate-200 overflow-x-auto shadow-3xs print:border-none print:shadow-none print:overflow-visible">
            <table className="min-w-full divide-y divide-slate-200 text-left text-xs bg-white text-slate-800 print:w-full print:table-fixed print:min-w-0" id="requests-audit-table">
              <thead className="bg-slate-50 text-slate-550 font-bold">
                <tr>
                  <th className="px-4 py-3 border-b border-slate-200 print:px-1.5 print:py-1.5 print:text-[8px] print:w-24">申請職員</th>
                  <th className="px-4 py-3 border-b border-slate-200 text-center w-32 print:px-1.5 print:py-1.5 print:text-[8px] print:w-24">希望日 / 曜日</th>
                  <th className="px-4 py-3 border-b border-slate-200 text-center w-28 print:px-1.5 print:py-1.5 print:text-[8px] print:w-24">希望内容</th>
                  <th className="px-4 py-3 border-b border-slate-200 print:px-1.5 print:py-1.5 print:text-[8px] print:w-20">最優先区分</th>
                  <th className="px-4 py-3 border-b border-slate-200 print:px-1.5 print:py-1.5 print:text-[8px] print:w-44">申請理由／コメント</th>
                  <th className="px-4 py-3 border-b border-slate-200 print:px-1.5 print:py-1.5 print:text-[8px] print:w-44">管理者コメント・特記</th>
                  <th className="px-4 py-3 border-b border-slate-200 text-center w-28 print:px-1.5 print:py-1.5 print:text-[8px] print:w-16">状況</th>
                  <th className="px-4 py-3 border-b border-slate-200 text-right w-44 print:hidden">審査決定</th>
                </tr>
              </thead>
              <tbody className="divide-y divide-slate-200">
                {filteredRequests.length === 0 ? (
                  <tr>
                    <td colSpan={8} className="text-center py-16 text-slate-400 font-semibold text-[11px] print:text-[9px]">
                      表示中の年月・選択フィルターに合致する希望申請は現在登録されていません。
                    </td>
                  </tr>
                ) : (
                  filteredRequests.map(req => {
                    const staff = staffList.find(s => s.id === req.staffId);
                    const { weekday } = getDayAndW(req.targetDate);
                    
                    // コメント入力管理
                    const currentComment = managerCommentInputs[req.id] !== undefined
                      ? managerCommentInputs[req.id]
                      : req.managerComment || '';

                    return (
                      <tr key={req.id} className={`hover:bg-slate-50/50 transition-colors ${
                        req.status === 'pending' ? 'bg-amber-50/10 font-medium' : ''
                      }`}>
                        
                        {/* 申請職員 (鈴木 花子 ST-002) */}
                        <td className="px-4 py-3 print:px-1.5 print:py-1 print:text-[8px]">
                          <div className="font-bold text-slate-900">{staff?.name || '不明'}</div>
                          <div className="text-[10px] text-slate-400 font-mono scale-95 origin-left print:hidden">ID: {req.staffId}</div>
                        </td>

                        {/* 希望日 / 曜日 */}
                        <td className="px-4 py-3 text-center print:px-1.5 print:py-1 print:text-[8px]">
                          <div className="font-mono text-xs print:text-[8px] font-extrabold text-slate-900">{req.targetDate}</div>
                          <div className={`text-[10px] print:text-[7px] font-bold ${
                            weekday === '日' ? 'text-red-500' : weekday === '土' ? 'text-blue-500' : 'text-slate-500'
                          }`}>
                            ({weekday})
                          </div>
                        </td>

                        {/* 希望内容 */}
                        <td className="px-4 py-3 text-center print:px-1.5 print:py-1 print:text-[8px]">
                          <span className={`text-[10px] print:text-[7px] font-bold px-2 py-0.5 rounded ${
                            req.requestType === '有休希望' || req.requestType === '有休確定'
                              ? 'bg-emerald-100 text-emerald-800'
                              : req.requestType === '希望休'
                              ? 'bg-rose-100 text-rose-800'
                              : req.requestType === '勤務不可'
                              ? 'bg-red-500 text-white'
                              : 'bg-indigo-50 text-indigo-805 border border-indigo-150'
                          }`}>
                            {req.requestType}
                          </span>
                        </td>

                        {/* 絶対・努力 */}
                        <td className="px-4 py-3 text-xs print:px-1.5 print:py-1 print:text-[8px]">
                          <span className={req.conditionType === 'absolute' ? 'text-red-600 font-bold' : 'text-slate-550'}>
                            {req.conditionType === 'absolute' ? '絶対' : '努力'}
                          </span>
                          {req.priority === 'high' && (
                            <span className="block text-[9px] print:text-[7px] text-amber-600 font-extrabold">🚨 高優先</span>
                          )}
                        </td>

                        {/* 申請理由／コメント */}
                        <td className="px-4 py-3 text-slate-700 italic max-w-xs break-all print:px-1.5 print:py-1 print:text-[8px] print:not-italic print:text-slate-900">
                          <div className="print:leading-tight">“{req.reason}”</div>
                          <div className="text-[9px] text-slate-405 font-mono not-italic mt-1 print:hidden">提出: {req.requestDate}</div>
                        </td>

                        {/* 管理者コメント・特記 */}
                        <td className="px-4 py-3 print:px-1.5 print:py-1 print:text-[8px]">
                          <input
                            type="text"
                            placeholder="管理者指摘や理由記入..."
                            value={currentComment}
                            onChange={(e) => {
                              setManagerCommentInputs({...managerCommentInputs, [req.id]: e.target.value});
                            }}
                            className="bg-slate-55 focus:bg-white text-[11px] px-2 py-1 rounded border border-slate-200 focus:outline-none focus:border-indigo-500 w-full font-sans transition-all print:hidden"
                          />
                          <span className="hidden print:inline text-[8px] text-slate-900 border-none bg-transparent break-all leading-tight">{currentComment || '—'}</span>
                        </td>

                        {/* 状況 */}
                        <td className="px-4 py-3 text-center print:px-1.5 print:py-1 print:text-[8px]">
                          {req.status === 'approved' && (
                            <span className="bg-emerald-50 text-emerald-805 border border-emerald-200 text-[10px] print:text-[7px] font-bold px-2 py-0.5 rounded">
                              承認
                            </span>
                          )}
                          {req.status === 'rejected' && (
                            <span className="bg-red-50 text-red-700 border border-red-200 text-[10px] print:text-[7px] font-bold px-2 py-0.5 rounded">
                              却下
                            </span>
                          )}
                          {req.status === 'needs_discussion' && (
                            <span className="bg-amber-50 text-amber-800 border border-amber-200 text-[10px] print:text-[7px] font-bold px-2 py-0.5 rounded">
                              要相談
                            </span>
                          )}
                          {req.status === 'pending' && (
                            <span className="bg-slate-100 text-slate-550 text-[10px] print:text-[7px] font-bold px-2 py-0.5 rounded-full border">
                              未審査
                            </span>
                          )}
                        </td>

                        {/* 審査決定アクション */}
                        <td className="px-4 py-3 text-right print:hidden">
                          <div className="flex gap-1 justify-end">
                            <button
                              onClick={() => handleReviewStatus(req.id, 'approved')}
                              className={`p-1 rounded text-[10px] font-bold cursor-pointer hover:bg-slate-100 ${
                                req.status === 'approved' ? 'text-indigo-600 bg-indigo-50/50' : 'text-slate-500'
                              }`}
                              title="承認する"
                            >
                              承認
                            </button>
                            <button
                              onClick={() => handleReviewStatus(req.id, 'rejected')}
                              className={`p-1 rounded text-[10px] font-bold cursor-pointer hover:bg-slate-100 ${
                                req.status === 'rejected' ? 'text-red-600 bg-red-50/50' : 'text-slate-500'
                              }`}
                              title="却下する"
                            >
                              却下
                            </button>
                            <button
                              onClick={() => handleReviewStatus(req.id, 'needs_discussion')}
                              className={`p-1 rounded text-[10px] font-bold cursor-pointer hover:bg-slate-100 ${
                                req.status === 'needs_discussion' ? 'text-amber-700 bg-amber-50' : 'text-slate-500'
                              }`}
                              title="保留・要相談に設定"
                            >
                              相談
                            </button>
                            
                            <button
                              onClick={() => handleDeleteRequest(req.id)}
                              className="text-red-400 hover:text-red-600 p-1 rounded hover:bg-red-50 cursor-pointer"
                              title="削除・取消"
                            >
                              消去
                            </button>
                          </div>
                        </td>

                      </tr>
                    );
                  })
                )}
              </tbody>
            </table>
          </div>

        </div>
      )}

      {/* --- サブタブコンテンツ C: 衝突(コンフリクト)分析エンジン --- */}
      {activeSubTab === 'conflict-check' && (
        <div className="space-y-4" id="conflict-check-panel">
          
          <div className="bg-white p-4.5 rounded-xl border border-slate-200/80 shadow-3xs space-y-2">
            <h3 className="text-xs font-bold text-slate-800">
              ⚡ シフト希望適合度・リアルタイム重複衝突検知一覧
            </h3>
            <p className="text-[11px] text-slate-500 leading-relaxed font-sans">
              登録＆承認済みのシフト希望に対し、実際の【予定勤務テーブル】および【夜間オンコール担当計画】に違反または矛盾した割り振りが行われていないかを自動的・俯瞰的に監査検証した結果です。
              絶対条件違反は <span className="text-red-600 font-bold">「絶対条件警告 (Critical)」</span> 、その他は努力義務違反としてイエロー表示されます。
            </p>
          </div>

          <div className="space-y-3">
            {currentConflicts.length === 0 ? (
              <div className="bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-xl p-6 text-center space-y-2 shadow-3xs">
                <CheckCircle className="h-8 w-8 text-emerald-600 mx-auto animate-bounce duration-5000" />
                <h4 className="text-sm font-bold">コンフリクト・配置衝突は一切ありません！</h4>
                <p className="text-xs text-emerald-700 max-w-md mx-auto">
                  承認された職員の希望休や有休希望、遅番・オンコール排除設定が、現在カレンダー上で作成されている全勤務表と100%美しく適合調和しています。監査適合性クリアです。
                </p>
              </div>
            ) : (
              currentConflicts.map((conf, index) => (
                <div 
                  key={conf.id + '-conflict-' + index}
                  className={`p-4 border rounded-xl shadow-3xs flex flex-col md:flex-row md:items-center justify-between gap-4 transition-all ${
                    conf.type === 'critical'
                      ? 'bg-rose-50/40 border-rose-220/80 ring-2 ring-rose-500/10'
                      : 'bg-white border-yellow-250/80'
                  }`}
                >
                  <div className="space-y-1.5 flex-1">
                    <div className="flex items-center gap-2">
                      <span className={`text-[10px] font-bold px-2 py-0.5 rounded-full ${
                        conf.type === 'critical'
                          ? 'bg-rose-600 text-white'
                          : 'bg-amber-100 text-amber-800 border border-amber-200'
                      }`}>
                        {conf.type === 'critical' ? '絶対条件違反 (要解消)' : '努力条件差異'}
                      </span>
                      
                      <span className="font-extrabold text-slate-900 text-xs">
                        {conf.dateStr} ({conf.weekday})
                      </span>

                      <span className="font-bold text-slate-800 text-xs text-indigo-700 ml-1">
                        職員: {conf.staffName}
                      </span>
                    </div>

                    <div className="text-xs text-slate-800 font-medium">
                      提出申請： <span className="font-bold underline">{conf.req.requestType}</span> (理由: {conf.req.reason})
                    </div>

                    <div className="text-[11px] text-red-700 font-bold flex items-center gap-1 bg-red-50/30 p-1.5 rounded border border-red-100 max-w-2xl font-sans leading-relaxed">
                      <AlertTriangle className="h-3.5 w-3.5 text-red-600 shrink-0" />
                      <span>{conf.message}</span>
                    </div>
                  </div>

                  {/* 管理者用デバッグ修正ボタン */}
                  {userRole !== 'Staff' && userRole !== 'Viewer' && (
                    <div className="flex items-center gap-2 shrink-0">
                      <div className="text-[10px] text-slate-400 font-mono text-center pr-2">
                        <div>割当シフト: {conf.rosterValue || '空'}</div>
                        <div>待機アサイン: {conf.onCallRole ? `${conf.onCallRole}担当` : 'なし'}</div>
                      </div>

                      <button
                        onClick={() => quickFixRosterToOff(conf.req.staffId, conf.req.targetDate)}
                        className="bg-white hover:bg-slate-50 text-slate-700 font-bold text-[11px] py-1.5 px-3 border border-slate-300 rounded-lg shadow-3xs transition-all cursor-pointer"
                        title="シフト表の割り当てを「休」に瞬時に切り替えて衝突を調停します"
                      >
                        「休み(休)」に変更して調停
                      </button>
                    </div>
                  )}

                </div>
              ))
            )}
          </div>

        </div>
      )}

    </div>
  );
}
