// src/components/ShiftRequestsManager.tsx
import React, { useState, useEffect } from 'react';
import { FacilitySettings, Staff, MonthlyRosterData, MonthlyOnCallData, ShiftRequest } from '../types';
import { getDaysInMonth, getDayOfWeekJapanese, isWeekend } from '../utils/dateUtils';
import { exportShiftRequests } from '../utils/excelExport';
import { 
  ClipboardList, 
  UserCheck, 
  AlertTriangle, 
  FileSpreadsheet, 
  PlusCircle, 
  CheckCircle, 
  XCircle, 
  HelpCircle, 
  Bookmark, 
  Calendar, 
  Lock, 
  Key, 
  CheckSquare, 
  Filter, 
  Trash2, 
  MessageSquare,
  ShieldCheck,
  Printer
} from 'lucide-react';

interface ShiftRequestsManagerProps {
  settings: FacilitySettings;
  staffList: Staff[];
  rosters: Record<string, MonthlyRosterData>;
  onCallData: MonthlyOnCallData;
  requests: ShiftRequest[];
  onUpdateRequests: (newRequests: ShiftRequest[]) => void;
  userRole: 'Admin' | 'Manager' | 'Staff' | 'Viewer';
  onUpdateRosters?: (newRosters: Record<string, MonthlyRosterData>) => void;
  onUpdateOnCall?: (newOnCall: MonthlyOnCallData) => void;
}

export default function ShiftRequestsManager({
  settings,
  staffList,
  rosters,
  onCallData,
  requests,
  onUpdateRequests,
  userRole,
  onUpdateRosters,
  onUpdateOnCall
}: ShiftRequestsManagerProps) {
  const targetYearMonth = settings.targetYearMonth;
  const daysInMonth = getDaysInMonth(targetYearMonth);
  const [yStr, mStr] = targetYearMonth.split('-');
  const [year, month] = [Number(yStr), Number(mStr)];

  const daysArray = Array.from({ length: daysInMonth }, (_, i) => i + 1);

  // 内部的なサブタブ選択: 'staff-portal' (申請画面) | 'manager-review' (一覧審査) | 'conflict-check' (衝突確認)
  const [activeSubTab, setActiveSubTab] = useState<'staff-portal' | 'manager-review' | 'conflict-check'>('manager-review');

  // --- シミュレーション職員ログイン機能用の状態（パスワード設定を含む） ---
  const [loggedInStaffId, setLoggedInStaffId] = useState<string>('S004'); // デフォルトは鈴木花子 S004
  const [passwordInput, setPasswordInput] = useState<string>('');
  const [isStaffAuthenticated, setIsStaffAuthenticated] = useState<boolean>(true); // デフォルトでシミュログイン状態にしてストレス軽減
  const [staffPasscodes, setStaffPasscodes] = useState<Record<string, string>>(() => {
    const saved = localStorage.getItem('roster_app_staff_passcodes');
    return saved ? JSON.parse(saved) : {
      'S001': '1234',
      'S002': '1234',
      'S003': '1234',
      'S004': '1234',
      'S005': '1234',
      'S006': '1234',
    };
  });
  const [passSettingMode, setPassSettingMode] = useState<boolean>(false);
  const [newPassword, setNewPassword] = useState<string>('');

  // 新規申請作成用フォーム
  const [formDate, setFormDate] = useState<string>(`${targetYearMonth}-10`);
  const [formRequestType, setFormRequestType] = useState<string>('希望休');
  const [formReason, setFormReason] = useState<string>('');
  const [formPriority, setFormPriority] = useState<'high' | 'medium' | 'low'>('medium');

  // 管理者検索フィルター
  const [filterStaff, setFilterStaff] = useState<string>('ALL');
  const [filterType, setFilterType] = useState<string>('ALL');
  const [filterStatus, setFilterStatus] = useState<string>('ALL');

  // オンライン管理者コメント編集一時保存
  const [managerCommentInputs, setManagerCommentInputs] = useState<Record<string, string>>({});

  // 曜日と日数の取得用ヘルパー
  const getDayAndW = (dateStr: string) => {
    try {
      const parts = dateStr.split('-');
      const ym = `${parts[0]}-${parts[1]}`;
      const d = Number(parts[2]);
      const weekday = getDayOfWeekJapanese(ym, d);
      return { dayNum: d, weekday };
    } catch (e) {
      return { dayNum: 1, weekday: '月' };
    }
  };

  // 申請区分に対応するデフォルト「条件区分 (絶対条件 or 努力条件)」の判定
  const getConditionTypeFromRequestType = (type: string): 'absolute' | 'preference' => {
    const absoluteTypes = ['勤務不可', '有休希望', '有休確定', '代休希望', '代休確定'];
    if (absoluteTypes.includes(type)) {
      return 'absolute';
    }
    return 'preference';
  };

  // ログイン暗号化/照合処理
  const handleStaffLogin = () => {
    const correctPin = staffPasscodes[loggedInStaffId] || '1234';
    if (passwordInput === correctPin) {
      setIsStaffAuthenticated(true);
      alert(`${staffList.find(s => s.id === loggedInStaffId)?.name} さんとして認証されました。希望申請の登録・履歴確認が可能です。`);
    } else {
      alert('暗証番号（パスワード）が正しくありません。初期設定は 1234 です。');
    }
  };

  // パスワードの更新
  const handleUpdatePassword = () => {
    if (!newPassword.trim()) {
      alert('新しいパスワードを入力してください。');
      return;
    }
    const updated = {
      ...staffPasscodes,
      [loggedInStaffId]: newPassword
    };
    setStaffPasscodes(updated);
    localStorage.setItem('roster_app_staff_passcodes', JSON.stringify(updated));
    setNewPassword('');
    setPassSettingMode(false);
    alert('パスワード（暗証番号）を正常に変更しました。以降この番号を使用してください。');
  };

  // 希望申請の自作追加処理
  const handleAddRequest = (e: React.FormEvent) => {
    e.preventDefault();
    if (!formDate) {
      alert('対象日を選択してください。');
      return;
    }
    // 対象日の年月整合確認
    if (!formDate.startsWith(targetYearMonth)) {
      alert(`申請対象日は現在の対象年月 [${targetYearMonth}] 内でなければなりません。`);
      return;
    }

    const currentStaffObj = staffList.find(s => s.id === loggedInStaffId);
    if (!currentStaffObj) return;

    const requestTypeLabel = formRequestType;
    const condType = getConditionTypeFromRequestType(requestTypeLabel);

    // 優先度
    const newReq: ShiftRequest = {
      id: `REQ-${targetYearMonth}-${Date.now().toString().slice(-4)}`,
      staffId: loggedInStaffId,
      targetMonth: targetYearMonth,
      requestDate: new Date().toISOString().split('T')[0],
      requestType: requestTypeLabel,
      conditionType: condType,
      targetDate: formDate,
      reason: formReason,
      priority: formPriority,
      status: 'pending', // 新規申請は未確認状態
      managerComment: '',
    };

    const updated = [newReq, ...requests];
    onUpdateRequests(updated);

    // フォームクリア
    setFormReason('');
    alert(`【${currentStaffObj.name}】 ${formDate}の「${requestTypeLabel}」申請を登録しました。管理者の承認をお待ちください。`);
  };

  // 申請の削除 (当事者の未承認状態、または管理者権限のみ可能)
  const handleDeleteRequest = (reqId: string) => {
    const target = requests.find(r => r.id === reqId);
    if (!target) return;
    
    const isManagerOrAdmin = userRole === 'Admin' || userRole === 'Manager';
    // スタッフはpending状態のみ削除可能
    if (!isManagerOrAdmin && target.status !== 'pending') {
      alert('確認・承認済みの申請は自分で削減・取消できません。管理者に連絡してください。');
      return;
    }

    if (confirm('この希望申請を削除（取り消し）します。よろしいですか？')) {
      const filtered = requests.filter(r => r.id !== reqId);
      onUpdateRequests(filtered);
    }
  };

  // 管理者審査 (承認・却下・要相談) & コメントを保存
  const handleReviewStatus = (reqId: string, newStatus: 'approved' | 'rejected' | 'needs_discussion') => {
    const isReadOnly = userRole === 'Staff' || userRole === 'Viewer';
    if (isReadOnly) {
      alert('権限がありません。管理者 (Admin / Manager) でログインしてください。');
      return;
    }

    const comment = managerCommentInputs[reqId] || '';

    const updated = requests.map(r => {
      if (r.id === reqId) {
        return {
          ...r,
          status: newStatus,
          managerComment: comment || r.managerComment,
          reviewedBy: userRole === 'Admin' ? '統括管理者' : '施設長サビ管',
          reviewedAt: new Date().toISOString().split('T')[0]
        };
      }
      return r;
    });

    onUpdateRequests(updated);
    alert(`申請を「${newStatus === 'approved' ? '承認' : newStatus === 'rejected' ? '却下' : '要相談'}」として審査確定しました。`);
  };

  // 管理者コメントの変更を一括反映できるようにする
  const handleSaveAllComments = () => {
    const updated = requests.map(r => {
      if (managerCommentInputs[r.id] !== undefined) {
        return {
          ...r,
          managerComment: managerCommentInputs[r.id],
          reviewedAt: new Date().toISOString().split('T')[0]
        };
      }
      return r;
    });
    onUpdateRequests(updated);
    alert('管理者コメントテキストをすべて一括保存しました。');
  };

  // 一括で現在の対象年月の全申請「承認」する
  const handleApproveAllPending = () => {
    const isReadOnly = userRole === 'Staff' || userRole === 'Viewer';
    if (isReadOnly) return;

    if (confirm('現在表示中の「未処理」のシフト希望申請を、すべて一括で「承認」にします。よろしいですか？')) {
      const updated = requests.map(r => {
        if (r.targetMonth === targetYearMonth && r.status === 'pending') {
          return {
            ...r,
            status: 'approved' as const,
            reviewedBy: '一括承認システム',
            reviewedAt: new Date().toISOString().split('T')[0]
          };
        }
        return r;
      });
      onUpdateRequests(updated);
      alert('一括承認を完了しました。衝突監査ログも自動再計算されます。');
    }
  };

  // シフト(Roster)に希望シフトを強制同期・適用させる！ (有休＝ホ, 休み＝休 など)
  const handleApplyApprovedHolidayToRoster = () => {
    if (!onUpdateRosters) {
      alert('システムエラー: ロスター書き込みハンドラーが指定されていません。');
      return;
    }

    const isReadOnly = userRole === 'Staff' || userRole === 'Viewer';
    if (isReadOnly) return;

    const approvedOffs = requests.filter(r => 
      r.targetMonth === targetYearMonth && 
      r.status === 'approved' && 
      ['希望休', '有休希望', '有休確定', '代休希望', '勤務不可'].includes(r.requestType)
    );

    if (approvedOffs.length === 0) {
      alert('同期対象となる「承認済み」の休暇申請（希望休、有休等）が今月はありません。');
      return;
    }

    if (confirm(`現在承認されている休暇関係の希望申請 ${approvedOffs.length}件 を、予定ロスター(シフト表)の休日マークとして上書き一括適用（同期）します。よろしいですか？`)) {
      const copyRosters = { ...rosters };
      
      approvedOffs.forEach(req => {
        const dayStr = req.targetDate.split('-')[2];
        const dayNum = String(Number(dayStr)); // "10" -> "10"
        
        if (!copyRosters[req.staffId]) {
          copyRosters[req.staffId] = {
            yearMonth: targetYearMonth,
            staffId: req.staffId,
            schedule: {},
            actual: {}
          };
        }

        // 適切な記号の割り振り
        let code = '休'; // 希望休・不可
        if (req.requestType === '有休希望' || req.requestType === '有休確定') {
          code = 'ホ'; // 有休扱い symbol
        } else if (req.requestType === '代休希望') {
          code = '代'; // 代休扱い symbol
        }
        
        copyRosters[req.staffId].schedule[dayNum] = code;
        copyRosters[req.staffId].actual[dayNum] = code; // 同様に
      });

      onUpdateRosters(copyRosters);
      alert(`「${approvedOffs.length}」件の承認済み休み希望を予定表に同期反映しました！`);
    }
  };

  // --- 高度な衝突(Conflict)分析エンジン ---
  const analyzeConflicts = () => {
    const activeRequests = requests.filter(r => r.targetMonth === targetYearMonth && r.status !== 'rejected');
    const conflictList: {
      id: string;
      req: ShiftRequest;
      staffName: string;
      dateStr: string;
      weekday: string;
      rosterValue: string;
      onCallRole: string; // "主", "副", or ""
      type: 'critical' | 'warning';
      message: string;
    }[] = [];

    activeRequests.forEach(req => {
      const staff = staffList.find(s => s.id === req.staffId);
      if (!staff) return;

      const parts = req.targetDate.split('-');
      const dNum = Number(parts[parts.length - 1]);
      const weekday = getDayOfWeekJapanese(targetYearMonth, dNum);

      // A. シフト側のコード
      const rosterObj = rosters[req.staffId];
      const assignedRosterCode = rosterObj?.schedule?.[String(dNum)] || '';

      // B. オンコール待機側
      const onCallOnDay = onCallData?.days?.[String(dNum)];
      let onCallRole = '';
      if (onCallOnDay) {
        if (onCallOnDay.staffId === req.staffId) onCallRole = '主';
        else if (onCallOnDay.subStaffId === req.staffId) onCallRole = '副';
      }

      // 衝突条件を順次チェック
      let hasConflict = false;
      let conflictMsg = '';
      let errorType: 'critical' | 'warning' = 'warning';

      const isOffSymbol = ['休', 'ホ', '代', '公', '有'].includes(assignedRosterCode);

      if (req.requestType === '希望休' || req.requestType === '有休希望' || req.requestType === '代休希望' || req.requestType === '勤務不可') {
        // 休み系統希望（承認済み or 申請中）なのに、ロスターに何かしらの勤務(日、遅、夜、早など)が入っている
        if (assignedRosterCode && !isOffSymbol) {
          hasConflict = true;
          errorType = req.conditionType === 'absolute' ? 'critical' : 'warning';
          conflictMsg = `【予定衝突】${req.requestType}日なのに、ロスターで「${assignedRosterCode}」が割り当てられています。`;
        }
      } else if (req.requestType === '遅番不可') {
        if (assignedRosterCode === '遅') {
          hasConflict = true;
          errorType = 'critical'; // 遅番不可は絶対条件
          conflictMsg = `【禁止業務】「遅番不可」の日ですが、遅番シフトが入っています。`;
        }
      } else if (req.requestType === 'オンコール不可') {
        if (onCallRole !== '') {
          hasConflict = true;
          errorType = 'critical'; // 基本絶対
          conflictMsg = `【禁止業務】「オンコール不可」の日ですが、夜間待機（${onCallRole}担当）にアサインされています。`;
        }
      } else if (req.requestType === '遅番希望') {
        // 遅番希望なのに日勤やその他が入っている/休み
        if (assignedRosterCode && assignedRosterCode !== '遅' && assignedRosterCode !== '休') {
          hasConflict = true;
          errorType = 'warning';
          conflictMsg = `【希望不一致】遅番希望日ですが、シフトは「${assignedRosterCode}」になっています。`;
        }
      } else if (req.requestType === '日勤希望') {
        if (assignedRosterCode && assignedRosterCode !== '日' && assignedRosterCode !== '休') {
          hasConflict = true;
          errorType = 'warning';
          conflictMsg = `【希望不一致】日勤希望日ですが、シフトは「${assignedRosterCode}」になっています。`;
        }
      } else if (req.requestType === '土日勤務不可') {
        const isWe = weekday === '土' || weekday === '日';
        if (isWe && assignedRosterCode && !isOffSymbol) {
          hasConflict = true;
          errorType = req.conditionType === 'absolute' ? 'critical' : 'warning';
          conflictMsg = `【予定不適合】「土日勤務不可」指定のある週末ですが、勤務が入っています。`;
        }
      }

      if (hasConflict) {
        (conflictList as any).push({
          id: req.id,
          req,
          staffName: staff.name,
          dateStr: req.targetDate,
          weekday,
          rosterValue: assignedRosterCode || '(未作成)',
          onCallRole,
          type: errorType,
          message: conflictMsg
        });
      }
    });

    return conflictList as any[];
  };

  const currentConflicts = analyzeConflicts();

  // --- 各種集計表示カウンター ---
  const activeMonthRequests = requests.filter(r => r.targetMonth === targetYearMonth);
  const preferredOffCount = activeMonthRequests.filter(r => r.requestType === '希望休').length;
  const paidLeaveCount = activeMonthRequests.filter(r => r.requestType === '有休希望' || r.requestType === '有休確定').length;
  const unavailableCount = activeMonthRequests.filter(r => r.requestType === '勤務不可').length;
  const lateShiftNeededCount = activeMonthRequests.filter(r => r.requestType === '遅番希望').length;
  const onCallNeededCount = activeMonthRequests.filter(r => r.requestType === 'オンコール希望').length;
  const pendingRequestsCount = activeMonthRequests.filter(r => r.status === 'pending').length;
  const conflictsCount = currentConflicts.length;

  // フィルタリングされた管理者閲覧用リスト
  const getFilteredRequests = () => {
    return activeMonthRequests.filter(req => {
      const matchStaff = filterStaff === 'ALL' || req.staffId === filterStaff;
      const matchType = filterType === 'ALL' || req.requestType === filterType;
      const matchStatus = filterStatus === 'ALL' || req.status === filterStatus;
      return matchStaff && matchType && matchStatus;
    });
  };

  const filteredRequests = getFilteredRequests();

  // Excelダウンロードハンドラー
  const handleExportExcelAll = () => {
    exportShiftRequests(settings, staffList, requests, rosters, onCallData);
  };

  // オンコール/ロスター勤務を即時変更できるデバッグ用クイックフィックス関数 (管理者用)
  const quickFixRosterToOff = (staffId: string, parsedDate: string) => {
    if (!onUpdateRosters) return;
    const dayStr = parsedDate.split('-')[2];
    const dayNum = String(Number(dayStr));

    const copy = { ...rosters };
    if (!copy[staffId]) return;

    copy[staffId] = {
      ...copy[staffId],
      schedule: {
        ...copy[staffId].schedule,
        [dayNum]: '休'
      },
      actual: {
        ...copy[staffId].actual,
        [dayNum]: '休'
      }
    };
    onUpdateRosters(copy);
    alert(`予定・実績を「休」に修正し、コンフリクトを調停しました。`);
  };

  return (
    <div className="space-y-6" id="shift-requests-root">
      
      {/* 1. 操作概要とExcel一括帳票出力ボタン */}
      <div className="bg-white rounded-xl border border-slate-200 p-4 shadow-3xs flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <div className="flex items-center gap-1.5 text-indigo-900 text-xs font-bold leading-normal mb-1">
            <ClipboardList className="h-4.5 w-4.5 text-indigo-650" />
            <span>【職員連絡連携・シフト希望一括監査調整システム】</span>
          </div>
          <p className="text-xs text-slate-500 leading-relaxed">
            対象年月ごとに職員からの希望休（絶対条件／努力条件）や有休希望、遅番・オンコール可否などを一括で受諾・コントロールします。自動生成(Draft)時での優先自動遵守や、既存ロスターとの衝突判定もリアルタイム自動動作。
          </p>
        </div>

        <button
          onClick={handleExportExcelAll}
          className="bg-emerald-650 hover:bg-emerald-700 text-white font-bold text-xs py-2 px-4 rounded-lg flex items-center justify-center gap-2 shadow-xs border border-emerald-750 transition-all shrink-0 cursor-pointer"
        >
          <FileSpreadsheet className="h-4.5 w-4.5 text-emerald-105" />
          <span>希望申請帳票 Excel一括保存</span>
        </button>
      </div>

      {/* 2. 7大要素 自動カウンターダッシュボード */}
      <div className="grid grid-cols-2 md:grid-cols-7 gap-3">
        {/* 希望休 */}
        <div className="bg-white border border-slate-200 rounded-xl p-3 text-center shadow-3xs">
          <span className="text-[10px] text-slate-400 font-bold block">希望休件数</span>
          <div className="mt-1 flex items-baseline justify-center gap-0.5">
            <span className="text-lg font-extrabold text-slate-800 font-mono">{preferredOffCount}</span>
            <span className="text-[10px] text-slate-500">件</span>
          </div>
        </div>

        {/* 有休希望 */}
        <div className="bg-white border border-slate-200 rounded-xl p-3 text-center shadow-3xs">
          <span className="text-[10px] text-slate-400 font-bold block">有休希望</span>
          <div className="mt-1 flex items-baseline justify-center gap-0.5">
            <span className="text-lg font-extrabold text-indigo-700 font-mono">{paidLeaveCount}</span>
            <span className="text-[10px] text-slate-500">件</span>
          </div>
        </div>

        {/* 勤務不可 */}
        <div className="bg-white border border-slate-200 rounded-xl p-3 text-center shadow-3xs">
          <span className="text-[10px] text-slate-400 font-bold block">勤務不可</span>
          <div className="mt-1 flex items-baseline justify-center gap-0.5">
            <span className="text-lg font-extrabold text-rose-700 font-mono">{unavailableCount}</span>
            <span className="text-[10px] text-slate-500">件</span>
          </div>
        </div>

        {/* 遅番希望 */}
        <div className="bg-white border border-slate-200 rounded-xl p-3 text-center shadow-3xs">
          <span className="text-[10px] text-slate-400 font-bold block">遅番要請</span>
          <div className="mt-1 flex items-baseline justify-center gap-0.5">
            <span className="text-lg font-extrabold text-amber-655 font-mono">{lateShiftNeededCount}</span>
            <span className="text-[10px] text-slate-500">品</span>
          </div>
        </div>

        {/* オンコール希望 */}
        <div className="bg-white border border-slate-200 rounded-xl p-3 text-center shadow-3xs">
          <span className="text-[10px] text-slate-400 font-bold block">オンコール要請</span>
          <div className="mt-1 flex items-baseline justify-center gap-0.5">
            <span className="text-lg font-extrabold text-teal-700 font-mono">{onCallNeededCount}</span>
            <span className="text-[10px] text-slate-500">日</span>
          </div>
        </div>

        {/* 未確認件数 */}
